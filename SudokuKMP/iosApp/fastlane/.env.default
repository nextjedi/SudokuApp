# Fastlane Environment Variables
# Copy this to .env and fill in your values

# Apple Developer Account
APPLE_ID=your_apple_id@email.com
TEAM_ID=DLQ4JM3YPQ

# App Configuration
APP_IDENTIFIER=com.nextjedi.sudoku

# App Store Connect API Key (recommended for CI/CD)
# Generate at: https://appstoreconnect.apple.com/access/integrations/api
# APP_STORE_CONNECT_KEY_ID=YOUR_KEY_ID
# APP_STORE_CONNECT_ISSUER_ID=YOUR_ISSUER_ID
# APP_STORE_CONNECT_KEY_CONTENT=BASE64_ENCODED_KEY
